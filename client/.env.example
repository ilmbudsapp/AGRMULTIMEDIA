# EmailJS (https://www.emailjs.com/) — javni ključ i ID-jevi iz dashboarda
# Šablon u EmailJS-u: name, email, message, title, time (kao u „Contact Us” šablonu)
# Na EmailJS → Account → Security dodajte origin-e: https://www.agrmultimedia.eu i https://agrmultimedia.eu
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# Toni's Autopflege demo (/demo/tonis-autopflege): WhatsApp ohne + und Leerzeichen, z.B. 4917012345678
# Optional: Anzeigezeile unter dem Button, z.B. +49 170 12345678
VITE_TONI_WHATSAPP_E164=
VITE_TONI_WHATSAPP_DISPLAY=
